# Secret token to protect /api/automate from unauthorized calls
AUTOMATE_SECRET=your_secret_token_here

# Upstash Redis (for deduplication) — get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your_instagram_page_access_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id

# Facebook Graph API
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id

# X (Twitter) — cookie-based auth, no API credits needed
# agent-twitter-client uses your account credentials directly
X_USERNAME=your_x_username_without_@
X_PASSWORD=your_x_account_password
X_EMAIL=your_x_account_email
# Optional: paste JSON cookie array here to skip login on cold start
# Get it by running: node -e "const {Scraper}=require('agent-twitter-client');const s=new Scraper();s.login('USER','PASS','EMAIL').then(()=>s.getCookies()).then(c=>console.log(JSON.stringify(c)))"
X_COOKIES=
